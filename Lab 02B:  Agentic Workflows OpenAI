ROUTES = {
    "technical": "You are a senior technical expert. Be precise and structured.",
    "business": "You are a business strategist. Focus on ROI and impact.",
}

def classify_topic(topic: str) -> str:
    if not topic.strip():
        return "technical"
    res = chat([
        {"role": "system", "content": "Classify as 'technical' or 'business'. One word only."},
        {"role": "user", "content": topic},
    ]).lower()
    return res if res in ROUTES else "technical"


def evaluate(text: str) -> tuple[dict, str]:
    raw = chat([
        {"role": "system", "content": "Return JSON: {\"clarity\": int, \"accuracy\": int, \"brevity\": int, \"feedback\": str}"},
        {"role": "user", "content": text[:1000]},
    ])
    try:
        parsed = json.loads(raw)
    except:
        parsed = {"clarity": 5, "accuracy": 5, "brevity": 5, "feedback": "Fallback feedback"}
    scores = {k: int(parsed.get(k, 5)) for k in ["clarity", "accuracy", "brevity"]}
    return scores, parsed.get("feedback", "")

def improve(text: str, feedback: str, category: str) -> str:
    return chat([
        {"role": "system", "content": f"You are a {category} writer. Improve the text based on feedback. Keep it concise."},
        {"role": "user", "content": f"Text:\n{text}\nFeedback:\n{feedback}"},
    ])


def worker(topic: str) -> tuple[str, str, str]:
    category = classify_topic(topic)

   
    draft = chat([
        {"role": "system", "content": f"You are a {category} writer. Write a clear ~150-word article."},
        {"role": "user", "content": f"Topic: {topic}"},
    ])

    
    final_output = draft
    MAX_ITER = 4
    iteration = 1
    while iteration <= MAX_ITER:
        scores, feedback = evaluate(final_output)
        if all(v >= 7 for v in scores.values()):
            break
        final_output = improve(final_output, feedback, category)
        iteration += 1

    return topic, category, draft, final_output


def run_pipeline_for_queries(queries: list[str]):
    with ThreadPoolExecutor(max_workers=len(queries)) as pool:
        results = list(pool.map(worker, queries))

    for topic, category, draft, final_output in results:
        display(Markdown(f"# 🚀 Content Pipeline\n\n**Topic:** {topic}"))
        display(Markdown(f"## 🔀 Routed as: `{category}`"))
        display(Markdown("## 📝 Initial Draft\n\n" + draft))
        display(Markdown("## 🎯 Final Output\n\n" + final_output))
        display(Markdown("---"))


queries = [
    "AI-Powered CCTV Systems: Real-Time Object Detection Algorithms and Their Business Impact on Smart City Security",
    "How can AI improve marketing campaign performance and conversion rates?",
]

run_pipeline_for_queries(queries)
