def evaluate_research(goal: str, qa_pairs: dict[str, str]) -> dict:

    context = "\n\n".join(f"Q: {q}\nA: {a}" for q, a in qa_pairs.items())
    #print("Context = ", context)
    evaluation_raw = chat([
 

        {
            "role": "system",
            "content": (
                "You are a STRICT research evaluator.\n\n"
                "Mark 'sufficient' as FALSE if:\n"
                "- Any part of the goal is not clearly explained\n"
                "- Answers are shallow, vague, or incomplete\n"
                "- Answers are less than ~1000 words\n"
                "- Missing examples, comparisons, or real-world context\n\n"
                "Only mark TRUE if the research fully and clearly answers the goal in depth.\n\n"
                "Return ONLY JSON:\n"
                "{\n"
                '  "sufficient": true/false,\n'
                '  "follow_up_questions": ["question1", "question2"]\n'
                "}"
        )
        },

        {
            "role": "user",
            "content": f"Goal:\n{goal}\n\nCurrent research:\n{context}"
        }
    ])

    clean = evaluation_raw.strip().removeprefix("```json").removeprefix("```").removesuffix("```").strip()

    return json.loads(clean)

