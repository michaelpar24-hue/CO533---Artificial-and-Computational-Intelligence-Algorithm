seed_topic = "Real-time object detection algorithms in AI CCTV systems"
openai_client = OpenAI(api_key=OPENAI_API_KEY)

messages = [
    {"role": "user", "content": f"Start a conversation about {seed_topic}."}
]

#print("This is a message", messages)
for turn in range(3):
    display(Markdown(f"## -= Turn {turn+1} =-"))


    messages.append({
        "role": "user",
        "content": "Generate one strong interview question. Return the question only."
    })

    response_q = openai_client.chat.completions.create(
        model=OPENAI_MODEL,
        messages=messages,
        temperature=1,
    )

    question = response_q.choices[0].message.content
   
    display(Markdown("### Question:\n\n" + question))

  
    messages.append({"role": "assistant", "content": question})


    messages.append({
        "role": "user",
        "content": "Answer the question concisely for a beginner, then propose one follow-up question."
    })

    print("This is a message", messages)

    response_a = openai_client.chat.completions.create(
        model=OPENAI_MODEL,
        messages=messages,
        temperature=1,
    )

    answer = response_a.choices[0].message.content
    display(Markdown("### Answer:\n\n" + answer))


    messages.append({"role": "assistant", "content": answer})


